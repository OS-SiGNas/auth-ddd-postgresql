{
	"name": "auth-ddd",
	"version": "0.0.1",
	"main": "dist/index.js",
	"type": "module",
	"keywords": [],
	"author": "Alfredo Manrique",
	"license": "MIT",
	"description": "Implement Auth using typescript/POO, SOLID and DDD",
	"scripts": {
		"start": "export NODE_ENV=production && node dist/index.js",
		"dev": "export NODE_ENV=development && nodemon --watch 'dist/**/*.js' --exec 'node dist/index.js'",
		"dev:concurrently": "concurrently 'pnpm run dev' 'pnpm run swc:watch'",
		"dev:tsx": "export NODE_ENV=development && tsx --watch ./src/index.ts",
		"dev:ts": "export NODE_ENV=development && nodemon --watch 'src/**/*.ts' --exec 'ts-node --esm src/index.ts'",
		"dev:tsc": "export NODE_ENV=development && nodemon --watch 'src/**/*.ts' --exec 'tsc && node dist/index.js'",
		"dev:node": "export NODE_ENV=development && node --experimental-loader=ts-node/esm --experimental-specifier-resolution=node --watch src/index.ts",
		"typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
		"migration:generate": "typeorm migration:generate ./migrations/PostRefactoring",
		"migration:run": "typeorm migration:run -- -d path-to-datasource-config",
		"build": "tsc",
		"swc": "swc src -d ./dist --strip-leading-paths",
		"swc:watch": "swc src -wd ./dist --strip-leading-paths",
		"prettier": "prettier --write src",
		"lint": "eslint ./src",
		"test": ""
	},
	"imports": {
		"#config": "./dist/config.js",
		"#Domain/*": "./dist/Domain/*",
		"#shared/*": "./dist/Applications/shared/*",
		"#auth/*": "./dist/Applications/auth/*",
		"#users/*": "./dist/Applications/users/*"
	},
	"devDependencies": {
		"@eslint/js": "^9.15.0",
		"@swc/cli": "^0.4.0",
		"@swc/core": "^1.9.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/eslint-plugin-security": "^3.0.0",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/node": "^20.17.6",
		"@types/nodemailer": "^6.4.17",
		"concurrently": "^9.1.0",
		"eslint": "^9.15.0",
		"eslint-plugin-security": "^3.0.1",
		"globals": "^15.12.0",
		"nodemon": "^3.1.7",
		"prettier": "^3.3.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.15.0"
	},
	"dependencies": {
		"@fastify/cors": "^10.0.1",
		"@fastify/helmet": "^12.0.1",
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"express": "5.0.0",
		"fastify": "5.0.0-alpha.4",
		"helmet": "^7.2.0",
		"jsonwebtoken": "^9.0.2",
		"nodemailer": "^6.9.16",
		"pg": "^8.13.1",
		"reflect-metadata": "^0.2.2",
		"tsx": "^4.19.2",
		"typeorm": "^0.3.20",
		"winston": "^3.17.0",
		"zod": "^3.23.8"
	}
}
