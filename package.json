{
	"name": "auth-ddd",
	"version": "0.0.1",
	"main": "dist/index.js",
	"type": "module",
	"keywords": [],
	"author": "Alfredo Manrique",
	"license": "MIT",
	"description": "Implement Auth using typescript/POO, SOLID and DDD",
	"scripts": {
		"start": "node dist/index.js",
		"dev": "nodemon --watch 'dist/**/*.js' --exec 'node dist/index.js'",
		"dev:concurrently": "concurrently 'pnpm run dev' 'pnpm run swc:watch'",
		"dev:swc": "nodemon --watch 'src/**/*.ts' --exec 'pnpm run swc:watch && node dis/index.js'",
		"dev:ts": "nodemon --watch 'src/**/*.ts' --exec 'ts-node --esm src/index.ts'",
		"dev:tsc": "nodemon --watch 'src/**/*.ts' --exec 'tsc && node dist/index.js'",
		"dev:node": "node --experimental-loader=ts-node/esm --experimental-specifier-resolution=node --watch src/index.ts",
		"typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
		"migration:generate": "typeorm migration:generate ./migrations/PostRefactoring",
		"migration:run": "typeorm migration:run -- -d path-to-datasource-config",
		"build": "tsc",
		"swc": "swc src -d ./dist --strip-leading-paths",
		"swc:watch": "swc src -wd ./dist --strip-leading-paths",
		"prettier": "prettier --write src",
		"test": ""
	},
	"devDependencies": {
		"@eslint/js": "^9.10.0",
		"@swc/cli": "^0.4.0",
		"@swc/core": "^1.7.26",
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/node": "^20.16.5",
		"concurrently": "^9.0.1",
		"eslint": "^9.10.0",
		"globals": "^15.9.0",
		"nodemon": "^3.1.4",
		"prettier": "^3.3.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.5.0"
	},
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "5.0.0",
		"fastify": "^4.28.1",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"pg": "^8.12.0",
		"reflect-metadata": "^0.2.2",
		"typeorm": "^0.3.20",
		"zod": "^3.23.8"
	}
}
